# Copiar a .env en el servidor (DigitalOcean Droplet). No commitear .env con secretos reales.
# Ver README.md para descripción de cada variable.

# --- Perfil Spring (producción en cloud) ---
# cloud-test activa automáticamente el perfil prod + pool Hikari reducido (DO).
SPRING_PROFILES_ACTIVE=cloud-test
# Flyway: en Docker suele fijarse en docker-compose.prod.yml (true). Solo poner false si migras a mano.
# SPRING_FLYWAY_ENABLED=true

# --- Servidor HTTP ---
EFACTURA_PORT=8080
SERVER_PORT=8080

# --- PostgreSQL (Managed DigitalOcean) ---
DB_HOST=db-postgresql-nyc3-xxxxx.ondigitalocean.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=CAMBIAR
DB_URL_SUFFIX=?sslmode=require
DB_NAME=efactura

# --- Pool Hikari (plan DO pequeño) ---
HIKARI_MAXIMUM_POOL_SIZE=6
HIKARI_MINIMUM_IDLE=1
HIKARI_LEAK_DETECTION_MS=60000

# --- GHCR (compose) ---
GITHUB_REPOSITORY_OWNER=tu-org

# --- Seguridad JWT (producción: generar secretos fuertes) ---
JWT_SECRET=64-caracteres-hex-aleatorios
EFACTURA_CRYPTO_MASTER=64-caracteres-hex-aleatorios

# --- Suite Identity ---
EFACTURA_SUITE_IDENTITY_ENABLED=true
SUITE_JWT_ISSUER=http://159.89.41.88:8092
SUITE_JWT_AUD=suite
SUITE_JWT_SECRET=mismo-secreto-que-identity-gateway
SUITE_IDENTITY_PUBLIC_BASE_URL=http://159.89.41.88:8092
EFACTURA_SUITE_IDENTITY_COMPANY_SLUG=suite-demo
# URLs de los frontends (redirecciones desde eFactura UI vía GET /api/public/v1/auth/suite-identity)
SUITE_SHELL_BASE_URL=http://159.89.41.88:4300
CARTERA_UI_BASE_URL=http://159.89.41.88:4301
POS_UI_BASE_URL=http://159.89.41.88:4220

# --- Integración sri-download-service ---
EFACTURA_SRI_DOWNLOAD_ENABLED=true
EFACTURA_SRI_DOWNLOAD_BASE_URL=http://159.89.41.88:8085
EFACTURA_SRI_DOWNLOAD_API_KEY=mismo-valor-que-SRI_DL_SERVICE_API_KEY

# --- CORS y URL pública de la app (fronts en el Droplet) ---
CORS_ORIGINS=http://159.89.41.88:4200,http://159.89.41.88:4300,http://159.89.41.88:4301,http://159.89.41.88:4220
APP_BASE_URL=http://159.89.41.88:4200

# --- Suite: bootstrap tenant vía API pública (prod: false) ---
EFACTURA_SUITE_TENANT_BOOTSTRAP=false

# --- Notificaciones (opcional) ---
NOTIFICATIONS_ENABLED=true
BREVO_API_KEY=

# --- Integraciones nube (Google Drive / OneDrive para adjuntos en cotizaciones) ---
EFACTURA_CLOUD_INTEGRATIONS_ENABLED=false
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8080/api/web/v1/integraciones/cloud/google/callback
MICROSOFT_DRIVE_CLIENT_ID=
MICROSOFT_DRIVE_CLIENT_SECRET=
MICROSOFT_DRIVE_REDIRECT_URI=http://localhost:8080/api/web/v1/integraciones/cloud/microsoft/callback

# --- Bootstrap (desactivar en prod estable) ---
EFACTURA_BOOTSTRAP=false

# --- Almacenamiento (volúmenes Docker; Spaces opcional vía EFACTURA_STORAGE_PROVIDER) ---
EFACTURA_STORAGE_PROVIDER=local
EFACTURA_STORAGE_LOCAL=/data/certificados
EFACTURA_COMPROBANTES_LOCAL=/data/comprobantes
EFACTURA_LOGOS_LOCAL=/data/logos
