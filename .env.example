# Copiar a .env en el servidor (DigitalOcean Droplet). No commitear .env con secretos reales.
# Ver README.md para descripción de cada variable.

# --- Perfil Spring (producción en cloud) ---
SPRING_PROFILES_ACTIVE=cloud-test

# --- Servidor HTTP ---
EFACTURA_PORT=8080
SERVER_PORT=8080

# --- PostgreSQL (Managed DigitalOcean) ---
DB_HOST=db-postgresql-nyc3-xxxxx.ondigitalocean.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=CAMBIAR
DB_URL_SUFFIX=?sslmode=require
DB_NAME=efactura

# --- Pool Hikari (plan DO pequeño) ---
HIKARI_MAXIMUM_POOL_SIZE=6
HIKARI_MINIMUM_IDLE=1
HIKARI_LEAK_DETECTION_MS=60000

# --- GHCR (compose) ---
GITHUB_REPOSITORY_OWNER=tu-org

# --- Seguridad JWT (producción: generar secretos fuertes) ---
JWT_SECRET=64-caracteres-hex-aleatorios
EFACTURA_CRYPTO_MASTER=64-caracteres-hex-aleatorios

# --- Suite Identity ---
EFACTURA_SUITE_IDENTITY_ENABLED=true
SUITE_JWT_ISSUER=https://identity.tudominio.com
SUITE_JWT_AUD=suite
SUITE_JWT_SECRET=mismo-secreto-que-identity-gateway
SUITE_IDENTITY_PUBLIC_BASE_URL=https://identity.tudominio.com
EFACTURA_SUITE_IDENTITY_COMPANY_SLUG=suite-demo

# --- Integración sri-download-service ---
EFACTURA_SRI_DOWNLOAD_ENABLED=true
EFACTURA_SRI_DOWNLOAD_BASE_URL=https://sri.tudominio.com
EFACTURA_SRI_DOWNLOAD_API_KEY=mismo-valor-que-SRI_DL_SERVICE_API_KEY

# --- CORS y URL pública de la app ---
CORS_ORIGINS=https://app.tudominio.com,https://suite.tudominio.com
APP_BASE_URL=https://app.tudominio.com

# --- Notificaciones (opcional) ---
NOTIFICATIONS_ENABLED=true
BREVO_API_KEY=

# --- Bootstrap (desactivar en prod estable) ---
EFACTURA_BOOTSTRAP=false

# --- Almacenamiento (volúmenes Docker; Spaces opcional vía EFACTURA_STORAGE_PROVIDER) ---
EFACTURA_STORAGE_PROVIDER=local
EFACTURA_STORAGE_LOCAL=/data/certificados
EFACTURA_COMPROBANTES_LOCAL=/data/comprobantes
EFACTURA_LOGOS_LOCAL=/data/logos
