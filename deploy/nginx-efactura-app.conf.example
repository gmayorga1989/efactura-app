# /etc/nginx/sites-available/efactura-api
# API efactura-app (Docker localhost:8080)
#
# DNS: api-efactura.appluxora.com → IP del Droplet
#
# En el servidor:
#   sudo cp /opt/efactura-app/nginx.conf.example /etc/nginx/sites-available/efactura-api
#   sudo ln -sf /etc/nginx/sites-available/efactura-api /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d api-efactura.appluxora.com

server {
    listen 80;
    listen [::]:80;
    server_name api-efactura.appluxora.com;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 60s;
        client_max_body_size 20m;
    }
}
